{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.sparta.agent",
  "asar": true,
  "asarUnpack": ["python/**", "node_modules/node-pty/**/*"],
  "productName": "Sparta Agent",
  "directories": {
    "output": "release/${version}"
  },
  "files": [
    "dist",
    "dist-electron",
    "node_modules/node-pty/**/*"
  ],
  "extraResources": [
    {
      "from": "python",
      "to": "python",
      "filter": ["**/*"]
    },
    {
      "from": "rust/sparta-security",
      "to": "rust/sparta-security",
      "filter": ["*.node", "index.js", "index.d.ts"]
    },
    // Python embebido para distribución (sin depender del Python del sistema)
    // Requiere: node scripts/fetch-embedded-python.js && node scripts/setup-embedded-python.js
    {
      "from": "vendor/python-${env.TARGET_PLATFORM}",
      "to": "python-runtime",
      "filter": ["**/*"]
    }
  ],
  "icon": "public/sparta-icon.png",
  "mac": {
    "target": ["dmg"],
    "artifactName": "Sparta-Agent-Mac-${version}-Installer.${ext}"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "artifactName": "Sparta-Agent-Windows-${version}-Setup.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  },
  "linux": {
    "target": ["AppImage"],
    "artifactName": "Sparta-Agent-Linux-${version}.${ext}"
  }
}
