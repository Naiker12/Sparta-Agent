{
  "_comment": "Copy this file to sparta.mcp.json and fill in your credentials. sparta.mcp.json is gitignored.",
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "<your-github-token>"
      },
      "enabled": false,
      "timeout": 30,
      "tools": {
        "include": [],
        "exclude": []
      }
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/allowed/dir"],
      "env": {},
      "enabled": false,
      "timeout": 30
    },
    "notion": {
      "type": "http",
      "url": "https://mcp.notion.com/mcp",
      "headers": {
        "Authorization": "Bearer <your-notion-integration-token>"
      },
      "enabled": false,
      "timeout": 60
    }
  }
}
