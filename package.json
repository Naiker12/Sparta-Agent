{
  "name": "sparta-agent",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "sidecar:setup": "cd python && python -m venv .venv && .venv\\Scripts\\pip install -r requirements.txt -r requirements-dev.txt",
    "sidecar:test": "cd python && .venv\\Scripts\\python -m pytest sparta_ai/tests/ -v",
    "sidecar:run": "cd python && .venv\\Scripts\\python sparta_ai/main.py",
    "rust:build": "cd rust\\sparta-security && cargo build --release",
    "rust:test": "cd rust\\sparta-security && cargo test",
    "rust:napi": "cd rust\\sparta-security && npx napi build --platform --release",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.101.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.41.0",
    "lucide-react": "^1.21.0",
    "monaco-editor": "^0.55.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "com.sparta.agent",
    "productName": "Sparta Agent",
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "public/sparta-escritorio.png",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "public/sparta-escritorio.png",
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "icon": "public/sparta-escritorio.png",
      "target": [
        "AppImage"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "main": "dist-electron/main.js",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
