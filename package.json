{
  "name": "sparta-agent",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "bin": {
    "sparta": "./bin/sparta.mjs"
  },
  "scripts": {
    "predev": "npm run rust:napi:if-missing",
    "prebuild": "npm run rust:napi",
    "dev": "vite",
    "dev:web": "vite --mode web",
    "build": "tsc && vite build && electron-builder",
    "build:web": "vite build --mode web",
    "preview:web": "vite preview --outDir dist-web",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "sparta": "node ./bin/sparta.mjs",
    "sidecar:setup": "node ./bin/sparta.mjs install",
    "sidecar:test": "cd python && node -e \"process.exit(process.platform === 'win32' ? 0 : 1)\" && .venv\\Scripts\\python -m pytest sparta_ai/tests/ -v || cd python && .venv/bin/python -m pytest sparta_ai/tests/ -v",
    "sidecar:run": "cd python && node -e \"process.exit(process.platform === 'win32' ? 0 : 1)\" && .venv\\Scripts\\python -m sparta_ai.main || cd python && .venv/bin/python -m sparta_ai.main",
    "sidecar:web": "cd python && node -e \"process.exit(process.platform === 'win32' ? 0 : 1)\" && .venv\\Scripts\\python -m sparta_ai.server_web || cd python && .venv/bin/python -m sparta_ai.server_web",
    "rust:build": "cd rust/sparta-security && cargo build --release",
    "rust:test": "cd rust/sparta-security && cargo test",
    "rust:napi": "cd rust/sparta-security && npx napi build --platform --release",
    "rust:napi:if-missing": "node scripts/build-rust-if-missing.cjs",
    "python:fetch": "node scripts/fetch-embedded-python.cjs",
    "python:setup": "node scripts/setup-embedded-python.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "rebuild-native": "npx @electron/rebuild -f -w node-pty"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@emotion/is-prop-valid": "^1.4.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.101.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "framer-motion": "^12.41.0",
    "lucide-react": "^1.21.0",
    "monaco-editor": "^0.55.1",
    "next-themes": "^0.4.6",
    "node-pty": "^1.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "react-use-measure": "^2.1.7",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/d3": "^7.4.3",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "playwright": "1.61.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^2.1.9"
  },
  "main": "dist-electron/main.js",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty"
    ]
  }
}
